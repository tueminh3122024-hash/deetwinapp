{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/_expo/(.*)", "destination": "/_expo/$1" },
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/favicon.ico", "destination": "/favicon.ico" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
